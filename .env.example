# PostgreSQL
DATABASE_URL=postgres://m365kg:m365kg_dev_password@localhost:5432/m365kg

# Neo4j
NEO4J_URI=neo4j://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=m365kg_dev_password

# M365 Connector
M365_TENANT_ID=your-tenant-id
M365_CLIENT_ID=your-client-id
M365_CLIENT_SECRET=your-client-secret

# LLM Service (Rust gRPC)
LLMSVC_ADDR=localhost:9090
NLP_MODE=2

# Cloud LLM (read by llm-svc, not Go backend)
LLM_API_BASE_URL=https://mkp-api.fptcloud.com/v1
LLM_API_KEY=your-api-key
LLM_MODEL=gpt-4o-mini

# Local Model Configuration
BRAIN_LOCAL_PROVIDER=qwen3-8b-q4
BRAIN_FALLBACK_TO_CLOUD=true

# Authentication
JWT_SECRET=your-jwt-secret-min-32-chars
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Scheduling
DELTA_SYNC_INTERVAL=3600

# Logging
LOG_LEVEL=info
