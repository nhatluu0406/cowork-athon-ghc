# M365 Knowledge Graph — Configuration Examples
# ============================================================
# DEFAULT: SQLite + LanceDB (Windows Desktop App, Cowork GHC)
# ============================================================

# Database Stack Selection
DB_TYPE=sqlite_lancedb

# SQLite Configuration (Desktop App — DEFAULT)
# For Windows: file:///C:/Users/YourUsername/AppData/Local/Cowork GHC/m365kg.db?cache=shared
# For Linux/Mac: file:./m365kg.db?cache=shared
DATABASE_URL=file:./m365kg.db?cache=shared

# ============================================================
# ALTERNATIVE: PostgreSQL + Neo4j (Server Deployments)
# Uncomment the below and comment out SQLite above
# ============================================================

# DB_TYPE=postgres_neo4j
# DATABASE_URL=postgres://postgres:password@localhost:5432/m365kg
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=your-neo4j-password

# ============================================================
# Shared Configuration (Both Options)
# ============================================================

# Server Configuration
HOST=0.0.0.0
PORT=8080
ENVIRONMENT=development

# Security
JWT_SECRET=your-32-character-or-longer-secret-key-here

# Microsoft 365 Integration
M365_TENANT_ID=your-azure-tenant-id
M365_CLIENT_ID=your-app-registration-client-id
M365_CLIENT_SECRET=your-app-registration-client-secret
M365_AUTH_MODE=entra_id

# M365 Sync
DELTA_SYNC_INTERVAL=300  # seconds (default: 5 minutes)

# CORS & Origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional: LLM Service Integration (for embeddings and entity extraction)
# Leave empty to disable embeddings (graceful degradation)
LLMSVC_ADDR=localhost:50051
LLMSVC_TLS=false
LLMSVC_CERT_FILE=

# Optional: OAuth Redirect URI (for Entra ID callback)
OAUTH_REDIRECT_URI=http://localhost:8080/api/auth/callback

# Optional: Dev Login (development/testing only)
# DEV_LOGIN_USERNAME=dev@example.com
# DEV_LOGIN_PASSWORD=dev-password
# ADMIN_USER_IDS=dev@example.com,admin@example.com

# ============================================================
# LLM Model Configuration (if using llm-svc)
# ============================================================

LLM_MODEL=gpt-4o-mini
LLM_EMBED_MODEL=text-embedding-3-small

# ============================================================
# Notes
# ============================================================
#
# 1. SQLite (DEFAULT):
#    - No external database service needed
#    - Perfect for Windows desktop (Cowork GHC)
#    - Database file created automatically at DATABASE_URL path
#    - Use file:/// prefix for absolute paths
#
# 2. PostgreSQL + Neo4j:
#    - For server deployments with multiple users
#    - Requires running PostgreSQL 15+ and Neo4j 5.x
#    - Use docker-compose.yml to start local dev stack
#
# 3. JWT_SECRET:
#    - Must be at least 32 characters
#    - Keep this secure in production
#    - Generate: openssl rand -base64 32
#
# 4. M365 Integration:
#    - Requires Azure App Registration
#    - Scopes needed: Mail.Read, Files.Read.All, etc.
#    - See docs/INTEGRATION.md for full scope list
#
# 5. LLMSVC_ADDR:
#    - Optional for embeddings and LLM features
#    - Leave empty for degraded mode (no embeddings)
#    - Format: "host:port" (e.g., "localhost:50051")
#
# ============================================================
