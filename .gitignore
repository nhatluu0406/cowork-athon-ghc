# ─────────────────────────────────────────────────────────────────────────────
# Cowork GHC — .gitignore
# Loại trừ dependency, build/package artifact, runtime state, log, secret.
# GIỮ: source, canonical workflow (.agent-workflow/), machine state
# (.loop-engineer/state/), STATUS/TASKS/HANDOFF/MANIFEST, docs, evidence summary,
# checkpoints, reports, test fixture cần thiết, .env.example.
# ─────────────────────────────────────────────────────────────────────────────

# --- Local demo workspace (generated by scripts/demo-seed.bat) ---
demo-workspace/
node_modules/
**/node_modules/
.pnp
.pnp.js

# --- Build / compile output ---
dist/
**/dist/
build/
**/build/
out/
**/out/
*.tsbuildinfo
.vite/
**/.vite/
target/
**/target/
app/llm-svc/target/

# --- Electron packaging / release artifacts (large binaries) ---
dist-app/
release/
*.exe
*.blockmap
*.nsis
*.appx
*.msix
*.msi
builder-debug.yml
builder-effective-config.yaml

# --- OpenCode downloaded/runtime artifacts (if fetched locally) ---
opencode/
**/opencode.exe
**/opencode-*/

# --- Large vendor binaries (database/service distributions) ---
vendor/*.zip
vendor/**/*.zip
vendor/postgresql-*/
vendor/neo4j-*/

# --- Runtime / process state (PID, port, temp, logs) ---
.runtime/
**/.runtime/
*.pid
*.port

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Coverage / test output ---
coverage/
**/coverage/
.nyc_output/
*.lcov

# --- Local databases / caches ---
*.sqlite
*.sqlite3
*.db
.cache/
**/.cache/

# --- Crash dumps ---
*.dmp
crash-*.log

# --- Secrets / credentials (NEVER commit) ---
.env
.env.*
!.env.example
*.pem
*.key
*.pfx
*.p12
secrets.*
credentials.*
*credential-export*
*token*.txt

# --- Loop Engineer: reference source + scratch + raw temp (NOT the state/evidence) ---
.loop-engineer/source/
.loop-engineer/scratch/*
!.loop-engineer/scratch/.gitkeep

# --- Test-created workspace fixtures / scratch output ---
.tmp/
tmp/
**/__fixtures_out__/
scratchpad/

# --- OS / editor noise ---
.DS_Store
Thumbs.db
Desktop.ini
*~
*.swp
*.swo
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# --- Local TypeScript test output ---
**/tsc-out/
