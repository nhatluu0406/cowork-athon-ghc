# ─────────────────────────────────────────────────────────────────────────────
# Monorepo .gitignore — M365 Knowledge Graph + Cowork GHC
# Keep: source, docs, config, state, evidence. Exclude: dependencies, build output,
# secrets, runtime state, logs, caches.
# ─────────────────────────────────────────────────────────────────────────────

# --- Dependencies ---
node_modules/
**/node_modules/
.pnp
.pnp.js
app/backend/bin/
llm-svc/target/

# --- Build / compile output ---
dist/
**/dist/
build/
**/build/
out/
**/out/
*.tsbuildinfo
.vite/
**/.vite/
Frontend/dist/
Frontend/build/
Frontend/node_modules/

# --- Electron packaging / release artifacts (large binaries) ---
dist-app/
release/
*.exe
*.blockmap
*.nsis
*.appx
*.msix
*.msi
builder-debug.yml
builder-effective-config.yaml

# --- OpenCode downloaded/runtime artifacts (if fetched locally) ---
opencode/
**/opencode.exe
**/opencode-*/

# --- Runtime / process state (PID, port, temp, logs) ---
.runtime/
**/.runtime/
*.pid
*.port

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
Frontend/playwright-report/*
Frontend/test-results/*

# --- Coverage / test output ---
coverage/
*.out
*.test
**/coverage/
.nyc_output/
*.lcov

# --- Local databases / caches ---
*.sqlite
*.sqlite3
*.db
.cache/
**/.cache/

# --- Crash dumps ---
*.dmp
crash-*.log

# --- Secrets / credentials (NEVER commit) ---
.env
.env.local
.env.*.local
.env.*
!.env.example
*.pem
*.key
*.pfx
*.p12
secrets.*
credentials.*
*credential-export*
*token*.txt

# --- Loop Engineer: reference source + scratch + raw temp (NOT the state/evidence) ---
.loop-engineer/source/
.loop-engineer/scratch/*
!.loop-engineer/scratch/.gitkeep

# --- Test-created workspace fixtures / scratch output ---
.tmp/
tmp/
**/__fixtures_out__/
scratchpad/

# --- OS / editor noise ---
.DS_Store
Thumbs.db
Desktop.ini
*~
*.swp
*.swo
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
