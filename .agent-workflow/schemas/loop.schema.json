{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "cowork-ghc/loop.schema.json",
  "title": "Cowork GHC Loop",
  "type": "object",
  "required": ["id", "name", "status"],
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string", "pattern": "^L[0-9]+$" },
    "name": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["NOT_READY", "READY", "RUNNING", "BLOCKED", "REVIEW_REQUIRED", "VERIFY_REQUIRED", "COMPLETED", "STALE", "FAILED"]
    },
    "depends_on": { "type": "array", "items": { "type": "string", "pattern": "^L[0-9]+$" } },
    "completed_at": { "type": ["string", "null"] },
    "inputs": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "path": { "type": "string" },
          "sha256": { "type": "string" },
          "repository": { "type": "string" },
          "commit": { "type": "string" },
          "name": { "type": "string" },
          "version": { "type": "string" }
        }
      }
    },
    "outputs": { "type": "array", "items": { "type": "string" } },
    "gate": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "result": { "type": "string", "enum": ["PASS", "PARTIAL", "FAIL", "PENDING"] },
        "evidence": { "type": "array", "items": { "type": "string" } }
      }
    },
    "invalidated": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "at": { "type": "string" },
        "reason": { "type": "string" }
      }
    }
  }
}
