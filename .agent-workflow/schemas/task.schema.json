{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "cowork-ghc/task.schema.json",
  "title": "Cowork GHC Task",
  "type": "object",
  "required": ["id", "status", "owner", "reviewer"],
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string", "pattern": "^CGHC-[0-9]{3,}$" },
    "requirement": { "type": "string" },
    "capability": { "type": "string" },
    "vertical_slice": { "type": "string" },
    "owner": { "type": "string" },
    "reviewer": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["BACKLOG", "READY", "IN_PROGRESS", "BLOCKED", "REVIEW", "VERIFY", "DONE", "STALE", "FAILED"]
    },
    "priority": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"] },
    "dependencies": { "type": "array", "items": { "type": "string" } },
    "files": { "type": "array", "items": { "type": "string" } },
    "acceptance": { "type": "array", "items": { "type": "string" } },
    "tests": { "type": "array", "items": { "type": "string" } },
    "evidence": { "type": "array", "items": { "type": "string" } },
    "risks": { "type": "array", "items": { "type": "string" } },
    "fingerprint": {
      "type": "object",
      "additionalProperties": true
    },
    "notes": { "type": "string" },
    "allOf": [
      {
        "$comment": "owner and reviewer must differ — enforced by controller validator, not by JSON Schema."
      }
    ]
  }
}
