# Enforce CRLF for Windows scripts so cmd.exe parses them correctly
# regardless of the OS where they were authored or checked out.
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Source files use LF (cross-platform default)
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.toml  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.md    text eol=lf
*.go    text eol=lf
*.rs    text eol=lf
*.sql   text eol=lf
*.cypher text eol=lf
