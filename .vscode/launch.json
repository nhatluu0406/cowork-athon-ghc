{
  "version": "0.2.0",
  "configurations": [

    {
      "name": "RAD Server (localhost:8080)",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/src/Backend/cmd/server",
      "cwd": "${workspaceFolder}/src/Backend/",
      "env": {
        // "RAD_JWT_SECRET": "dev-secret-key-change-in-production-12345",
        // "RAD_API_KEY": "dev-api-key-12345",
        // "RAD_ADMIN_EMAIL": "admin@example.com",
        // "RAD_ADMIN_PASSWORD": "AdminPassword$7x#",
        // "DATA_DIR": "./.rad/data",
        // // "REPO_PATH": "/home/dungpd4",
        // "LANCEDB_PATH": ".rad/lancedb",
        // "VITE_USE_PROXY": "false",
	      // "DEBUG": "true",
	      // "RAD_SETTINGS_FILE": "./MiniRAD/.rad/data/settings.json"
      },
      "args": [
       
      ],
      // "cwd": "${workspaceFolder}/src/Backend",
      "outputCapture": "std",
      "console": "integratedTerminal"
    },
    {
      "name": "Frontend (npm run dev)",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/src/Frontend/node_modules/.bin/vite",
      "args": [
        "dev"
      ],
      "cwd": "${workspaceFolder}/src/Frontend",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Attach to RAD Server",
      "type": "go",
      "request": "attach",
      "mode": "local",
      "processId": "${command:pickGoProcess}"
    },
    {
      "name": "Go Test",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${workspaceFolder}/src/Backend",
      "cwd": "${workspaceFolder}/src/Backend",
      "args": [
        "-test.v",
        "-test.run",
        "^${selectedText}$"
      ],
      "showLog": true
    }
  ],
  "compounds": [
    {
      "name": "Full Stack (Backend + Frontend)",
      "configurations": [
        "RAD Server (localhost:8080)",
        "Frontend (npm run dev)"
      ],
      "stopAll": true
    }
  ]
}
